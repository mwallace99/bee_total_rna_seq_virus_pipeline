# R session artefacts
.RData
.Rhistory

# PBS job stdout/stderr logs
*.pbs.e*
*.pbs.o*

# STAR writes Log.out to the working dir during genomeGenerate (stage 08)
Log.out

# Local run outputs and large data (these live on /g/data, not in git).
# Both cases: Linux is case-sensitive, so Results/ alone would not catch results/.
results/
Results/
names.txt

# Real sample sheets carry raw fastq filenames (barcodes etc.) and are
# study-specific, so they should not live in the public repo. The committed
# template is kept via the negation below.
*_rna_samples.txt
!example_rna_samples.txt

# Sequence data and alignments, wherever they land - a stray fastq or BAM in the
# checkout is never wanted and these files are far too big for git.
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bam
*.sam
*.fa
*.fasta
